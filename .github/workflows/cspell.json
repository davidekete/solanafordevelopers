{
  "version": "0.2",
  "language": "en",
  "words": [
    "fumadocs",
    "mdx",
    "frontmatter",
    "TypeScript",
    "JavaScript",
    "React",
    "Next.js",
    "vercel",
    "github",
    "workflow",
    "linting",
    "accessibility",
    "SEO",
    "metadata",
    "navbar",
    "sidebar",
    "breadcrumb",
